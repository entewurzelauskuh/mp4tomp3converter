root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
# `intellij_idea` is ktlint's style that matches IntelliJ's default Kotlin formatter, which
# follows the official Kotlin conventions — consistent with kotlin.code.style=official
# (gradle.properties). Spotless/ktlint format to this; the IDE agrees.
ktlint_code_style = intellij_idea
# Compose @Composable functions are PascalCase by convention — don't flag them.
ktlint_function_naming_ignore_when_annotated_with = Composable, Preview

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
